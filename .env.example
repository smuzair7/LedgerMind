# ---------------------------------------------------------------------------
# LedgerMind environment template
#
# IMPORTANT: Provider API keys (OpenAI, Anthropic, Google, etc.) are NEVER set
# here. They are supplied by the end user from the browser at runtime via the
# X-Provider-Key header and live only on request.state. This file is for
# infrastructure config only.
# ---------------------------------------------------------------------------

# ---------- Backend ----------
LEDGERMIND_ENV=dev                       # dev | prod
LEDGERMIND_HOST=0.0.0.0
LEDGERMIND_PORT=8000
LEDGERMIND_LOG_LEVEL=info
LEDGERMIND_CORS_ORIGINS=http://localhost:3000

# ---------- Database (sessions/messages/documents metadata) ----------
# Default is local SQLite under ./data/ledgermind.db
# For Postgres: postgresql+asyncpg://user:pass@host:5432/ledgermind
LEDGERMIND_DATABASE_URL=sqlite+aiosqlite:///./data/ledgermind.db

# ---------- Qdrant (vector DB) ----------
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
# Set to "memory" to skip Docker and run Qdrant in-process (no persistence).
QDRANT_MODE=server

# ---------- Redis (arq job queue) ----------
REDIS_URL=redis://redis:6379/0

# ---------- MinIO (S3-compatible file storage) ----------
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ledgermind
S3_REGION=us-east-1
S3_USE_SSL=false

# ---------- Embeddings / reranker ----------
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ---------- Frontend ----------
NEXT_PUBLIC_API_BASE=http://localhost:8000
